# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: for server-side admin operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Strava OAuth — create app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback

# App URL (production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated admin emails that can approve personal email registrations
ADMIN_EMAILS=admin@katoennatie.com